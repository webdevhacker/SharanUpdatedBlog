NODE_ENV=production
PORT=3000
CLIENT_URL=https://blog.isharankumar.com

# Database
MONGO_URI=mongodb://localhost:27017/techblog

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Email / SMTP
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=test@ethereal.email
SMTP_PASS=password
SMTP_FROM=noreply@isharankumar.com

# Set to true if behind a proxy like Nginx
TRUST_PROXY=true
